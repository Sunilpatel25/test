                           class="w-full p-3 bg-gray-700 border border-gray-600 text-white rounded-lg focus:ring-teal-500 focus:border-teal-500" required
                           minlength="5" maxlength="200">
                    <p id="validation-error" class="text-sm text-red-500 mt-1 hidden">Descriptor length must be between 5 and 200 characters.</p>
                </div>
                
                <div class="flex justify-end gap-3 mt-8">
                    <button type="button" onclick="closeModal()" class="px-6 py-3 bg-gray-600 text-white font-bold rounded-lg hover:bg-gray-500 transition">
                        Cancel Protocol
                    </button>
                    <button type="submit" id="modal-submit-btn" class="px-6 py-3 bg-teal-500 text-gray-900 font-extrabold rounded-lg hover:bg-teal-400 transition flex items-center shadow-md shadow-teal-500/20">
