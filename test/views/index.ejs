            const searchTerm = searchInput.value.toLowerCase().trim();
            if (searchTerm) {
                results = results.filter(task => 
                    task.description.toLowerCase().includes(searchTerm)
                );
            }
            
            // --- 2. Apply Sorting ---
            const sortCriteria = sortSelect.value.split('-'); // e.g., ['id', 'asc']
            const [key, direction] = sortCriteria;

            results.sort((a, b) => {
                let valA = a[key];
                let valB = b[key];

                if (key === 'description') {
                    // String comparison
                    valA = valA.toLowerCase();
                    valB = valB.toLowerCase();
                } else {
                    // Numeric comparison
                    valA = parseInt(valA);
                    valB = parseInt(valB);
                }

                if (valA < valB) return direction === 'asc' ? -1 : 1;
                if (valA > valB) return direction === 'asc' ? 1 : -1;
                return 0; // Descriptions are equal
            });

            // --- 3. (Mock) Status Filter is ignored for now as tasks don't have real status
            
            renderTasks(results);
        }

