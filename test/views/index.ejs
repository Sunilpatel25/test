<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quantum Project Console (Temporal Log)</title>
    <!-- Load Tailwind CSS (Using CDN for single-file mandate) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* --- Global & Theme Styling (Dark Mode, Inter Font) --- */
        body {
            font-family: 'Inter', sans-serif;
            background-color: #0d1117; /* Deep dark background */
            color: #e2e8f0; /* Light text */
            min-height: 100vh;
            position: relative;
            overflow-x: hidden;
            transition: background-color 0.5s;
        }

        /* --- Animated Background Effect (Simulated Quantum Field) --- */
        .quantum-field {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            opacity: 0.15;
            z-index: -1;
            background: radial-gradient(circle at 10% 20%, rgba(76, 29, 149, 0.5), transparent 40%),
                        radial-gradient(circle at 80% 90%, rgba(20, 184, 166, 0.5), transparent 50%);
            animation: pulse-glow 20s infinite alternate;
        }

        @keyframes pulse-glow {
            0% { transform: scale(1); opacity: 0.15; }
            100% { transform: scale(1.1); opacity: 0.3; }
        }

        /* --- Component Styling --- */
        .card {
            background-color: #161b22;
            border: 1px solid #30363d;
            border-radius: 0.75rem; /* rounded-xl */
            box-shadow: 0 10px 15px rgba(0, 0, 0, 0.3);
            transition: all 0.3s ease;
        }
        .task-row {
            transition: background-color 0.3s;
        }
        .task-row:hover {
            background-color: #21262d;
            box-shadow: 0 0 15px rgba(20, 184, 166, 0.2); /* Teal glow */
            transform: scale(1.01);
        }
        .modal-overlay {
            background-color: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(8px);
            z-index: 1000;
        }
        .hidden { display: none; }
        .spinner {
            border: 4px solid rgba(255, 255, 255, 0.3);
            border-top: 4px solid #4A90E2;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            animation: spin 0.8s linear infinite;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        /* EJS specific styles for rendering update form */
        .ejs-update-form {
            background-color: #2d1808; 
            border-left: 5px solid #fbbf24; 
            color: #fcd34d;
        }
        .text-neon-teal {
            color: #20c8a6; /* Custom bright teal */
        }
    </style>
</head>
<body class="p-4 md:p-8">
    <!-- Animated Quantum Field Background Element -->
    <div class="quantum-field"></div>

    <!-- EJS Initialization: Pulling server data into a global JS variable -->
    <script>
        // Initial data passed from Node.js (views/index.ejs)
        let tasksData = <%- JSON.stringify(tasks) %>;
        let isEditingTask = <%- JSON.stringify(currentTask) %>;
    </script>

    <div class="max-w-6xl mx-auto relative z-10">

        <!-- Header and Navigation -->
        <header class="flex justify-between items-center py-6 border-b border-gray-700 mb-8">
            <h1 class="text-3xl md:text-4xl font-extrabold text-neon-teal tracking-wider">
                &lt;QUANTUM PROJECT CONSOLE&gt;
            </h1>
            <nav>
                
            </nav>
        </header>

        <!-- Stats/Summary Section -->
        <div id="stats-dashboard" class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
            <div class="card p-6">
                <p class="text-sm font-semibold text-gray-400">Total Chronitons Logged</p>
                <p id="stat-total" class="text-3xl font-bold text-gray-100 mt-1"></p>
            </div>
            <div class="card p-6">
                <p class="text-sm font-semibold text-gray-400">Temporal Flux (Mock)</p>
                <p id="stat-progress" class="text-3xl font-bold text-yellow-500 mt-1">~0.78ms</p>
            </div>
            <div class="card p-6">
                <p class="text-sm font-semibold text-gray-400">Singularities Closed (Mock)</p>
                <p id="stat-completed" class="text-3xl font-bold text-green-500 mt-1">N/A</p>
            </div>
        </div>
        
        <!-- Main Controls: Search, Filter, Add New -->
        <div class="card p-6 mb-8">
            <h2 class="text-xl font-semibold text-gray-300 mb-4 border-b border-gray-700 pb-2">// Control Panel</h2>
            <div class="flex flex-col md:flex-row gap-4 items-center">
                
                <!-- Search Input -->
                <input type="text" id="search-input" placeholder="Search chronitons by descriptor..." 
                       class="flex-grow w-full md:w-auto p-3 bg-gray-700 border border-teal-500/50 text-white rounded-lg focus:ring-teal-500 focus:border-teal-500 transition duration-200">
                
                <!-- Sorting Dropdown -->
                <select id="sort-select" class="p-3 bg-gray-700 border border-gray-600 text-white rounded-lg">
                    <option value="id-asc">Sort by ID (Asc)</option>
                    <option value="id-desc">Sort by ID (Desc)</option>
                    <option value="desc-asc">Sort by Descriptor (A-Z)</option>
                    <option value="desc-desc">Sort by Descriptor (Z-A)</option>
                </select>

                <!-- Status Filter (Mock) -->
                <select id="status-filter" class="p-3 bg-gray-700 border border-gray-600 text-white rounded-lg">
                    <option value="all">Filter by Status (Mock)</option>
                    <option value="pending">Pending</option>
                    <option value="done">Done</option>
                </select>

                <!-- Add Task Button -->
                <button onclick="openCreateModal()" 
                        class="w-full md:w-auto px-6 py-3 bg-teal-500 text-gray-900 font-extrabold rounded-lg shadow-xl shadow-teal-500/30 hover:bg-teal-400 transition duration-150 transform hover:scale-[1.02]">
                    + Inject New Chroniton (C)
                </button>
            </div>
        </div>

        <!-- EJS-Rendered Update Form (for server-side edit initiation) -->
        <% if (currentTask) { %>
            <div class="ejs-update-form p-6 mb-8 rounded-xl shadow-md">
                <h2 class="text-2xl font-bold mb-4">RE-CALIBRATING Chroniton #<%= currentTask.id %></h2>
                <p class="mb-4">A manual server calibration session is active. Please commit changes below.</p>
                <form id="server-update-form" action="/tasks/update/<%= currentTask.id %>" method="POST" class="flex flex-col md:flex-row gap-4">
                    <input type="hidden" name="id" value="<%= currentTask.id %>">
                    <input type="text" name="newDescription" value="<%= currentTask.description %>" 
                           class="flex-grow p-3 bg-gray-700 border border-amber-400 rounded-lg text-white" required>
                    <button type="submit" class="px-6 py-3 bg-green-600 text-white font-bold rounded-lg hover:bg-green-500 transition shadow-lg">
                        <span id="update-status-text">Commit Changes (U)</span>
                    </button>
                    <a href="/" class="px-6 py-3 bg-gray-600 text-white font-bold rounded-lg hover:bg-gray-500 transition flex items-center justify-center">Abort</a>
                </form>
            </div>
        <% } %>

        <!-- Task List (R) -->
        <h2 class="text-2xl font-semibold text-gray-300 mb-4">// Temporal Log (Read Operations)</h2>
        <div class="card overflow-hidden">
            <table class="min-w-full divide-y divide-gray-700">
                <thead class="bg-gray-800">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Log ID</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Chroniton Descriptor</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Status (Mock)</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-400 uppercase tracking-wider">Calibration</th>
                    </tr>
                </thead>
                <tbody id="task-list-body" class="bg-gray-800 divide-y divide-gray-700">
                    <!-- Tasks will be dynamically populated here by EJS initially, and then managed by JS -->
                    <% if (tasks.length === 0) { %>
                        <tr>
                            <td colspan="4" class="px-6 py-4 text-center text-gray-500">Temporal Log is empty. Inject a new chroniton.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
        
        <!-- Pagination Section (Mock) -->
        <div id="pagination-controls" class="card flex justify-between items-center mt-6 p-4">
            <button id="prev-page" disabled class="px-4 py-2 bg-gray-700 text-gray-400 rounded-lg font-bold hover:bg-gray-600 transition">
                &larr; Previous Segment
            </button>
            <span id="page-info" class="text-gray-400">System Segment 1 of 1</span>
            <button id="next-page" disabled class="px-4 py-2 bg-gray-700 text-gray-400 rounded-lg font-bold hover:bg-gray-600 transition">
                Next Segment &rarr;
            </button>
        </div>

    </div>

    <!-- The Universal Modal (Client-side C/U Interface) -->
